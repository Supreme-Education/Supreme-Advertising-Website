# Copy to .env for local development (node server.js).
# For Netlify: add the SAME values under Site settings → Environment variables.
# No DATABASE_URL — SQLite via better-sqlite3, not Prisma.
ADMIN_PASSWORD=change-me-to-a-strong-password
SESSION_SECRET=change-me-to-a-long-random-string
PORT=3000

# Optional: import Yahoo contacts via CardDAV (use Yahoo App Password, not login password)
# YAHOO_EMAIL=you@yahoo.com
# YAHOO_APP_PASSWORD=
